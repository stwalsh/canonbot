{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CorpusChunk",
  "description": "A single stanza-level chunk from the Canon Bot poetry corpus",
  "type": "object",
  "required": [
    "chunk_id",
    "poet",
    "work",
    "poem_title",
    "date",
    "form",
    "period",
    "chunk_text",
    "chunk_index",
    "line_range",
    "source"
  ],
  "properties": {
    "chunk_id": {
      "type": "string",
      "description": "Unique identifier: poet-work-poem-index",
      "pattern": "^[a-z0-9-]+$"
    },
    "poet": {
      "type": "string",
      "description": "Full name of the poet"
    },
    "work": {
      "type": "string",
      "description": "Title of the collection or major work"
    },
    "poem_title": {
      "type": "string",
      "description": "Title of the individual poem"
    },
    "date": {
      "type": "integer",
      "description": "Publication year",
      "minimum": 1400,
      "maximum": 1950
    },
    "form": {
      "type": "string",
      "description": "Poetic form detected from structure",
      "enum": [
        "sonnet",
        "couplet",
        "stanzaic",
        "blank_verse",
        "song",
        "ode",
        "elegy",
        "epigram",
        "other"
      ]
    },
    "period": {
      "type": "string",
      "description": "Historical period derived from date",
      "enum": [
        "medieval",
        "early_modern",
        "restoration",
        "augustan",
        "romantic",
        "victorian"
      ]
    },
    "themes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "High-level thematic tags (filled later)"
    },
    "chunk_text": {
      "type": "string",
      "description": "The poetry text for this chunk"
    },
    "chunk_index": {
      "type": "integer",
      "description": "Zero-based index of this chunk within the poem",
      "minimum": 0
    },
    "line_range": {
      "type": "string",
      "description": "Line range within the poem, e.g. '1-6'",
      "pattern": "^\\d+(-\\d+)?$"
    },
    "stanza_range": {
      "type": "string",
      "description": "Stanza range, e.g. '1' or '1-3'"
    },
    "source": {
      "type": "string",
      "description": "Corpus source identifier"
    },
    "tcp_id": {
      "type": "string",
      "description": "EEBO-TCP identifier, if applicable"
    }
  },
  "additionalProperties": false
}
